#!/usr/bin/env bash
set -eu -o pipefail

export PROJDIR=$(cd "$(dirname "$0")" && pwd -P)

IMG=pactivate:deb11     # name of the image we build for testing

cd "$PROJDIR"
sudo -v -p '[sudo] password for %p (to run docker): '

#   Turn e.g. '-i -q' into '^(-i|-q)$' to let us find '-q' in arguments
args_words_regex="^($(IFS=\|; echo "$*"))$"
quiet=; [[ -q =~ $args_words_regex ]] && quiet=-q

./noncont-test "$@"

echo "Building container (this may take a few moments)...."
sudo docker build $quiet -t "$IMG" .
sudo docker run -it "$IMG" /test/cont-test "$@"
